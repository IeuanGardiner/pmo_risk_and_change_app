## Domain Model

### New types (`src/types/domain.ts`)

```typescript
export type IssueStatus = "Open" | "In Progress" | "Closed";

export interface Issue {
  issueReference: string;            // "I001", "I002", …  server-assigned
  scope: Scope;                      // "Project" | "Program"
  title: string;
  description: string;
  category: string;                  // from config.issueCategories
  priority: ChangePriority;          // reuse "Urgent"|"High"|"Standard"|"Low"
  status: IssueStatus;
  owner: string;
  raisedBy: string;
  projectId: string | null;          // null for Program scope
  estimatedCost: number;             // simple field — no calendar profile
  targetResolutionDate: string | null; // ISO date yyyy-mm-dd
  linkedRiskRefs: string[];
  linkedChangeRefs: string[];
  archived: boolean;
  createdAt: string;                 // ISO datetime, server-owned
  updatedAt: string;                 // ISO datetime, server-owned
}

export type IssueInput = Omit<
  Issue,
  "issueReference" | "archived" | "createdAt" | "updatedAt"
>;
```

### Extensions to existing types

```typescript
