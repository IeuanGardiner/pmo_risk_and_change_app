# Backend integration
# ---------------------------------------------------------------------------
# Leave VITE_API_BASE_URL unset (or empty) to run against the built-in mock
# data layer. Set it to your API root to switch every service to live HTTP
# calls — no code changes required.
#
#   VITE_API_BASE_URL=https://api.example.com
#
# The expected REST contract is documented in README.md.
VITE_API_BASE_URL=

# Microsoft Entra ID (Azure AD) — required when using @azure/msal-browser
# for token acquisition and silent renewal. Omit when using custom JWTs.
#
#   VITE_ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#   VITE_ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#   VITE_ENTRA_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_AUTHORITY=

# Azure Application Insights — wire in for client-side telemetry and error
# reporting. The connection string is found in the Azure portal under your
# Application Insights resource → Overview → Connection String.
#
#   VITE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
VITE_APPINSIGHTS_CONNECTION_STRING=
